# ========================================
# FlowTV - Bluehost .htaccess
# Enables gzip compression for JSON files
# ========================================

# Enable gzip compression
<IfModule mod_deflate.c>
    # Compress JSON files (critical for catalog performance)
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE application/xml
</IfModule>

# Enable browser caching for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    # JSON catalog data: cache for 6 hours (refreshed nightly)
    ExpiresByType application/json "access plus 6 hours"
    # Images: cache for 7 days
    ExpiresByType image/jpeg "access plus 7 days"
    ExpiresByType image/png "access plus 7 days"
    ExpiresByType image/webp "access plus 7 days"
    # CSS/JS: cache for 1 day
    ExpiresByType text/css "access plus 1 day"
    ExpiresByType application/javascript "access plus 1 day"
</IfModule>

# CORS headers for catalog_data (allow your domain)
<IfModule mod_headers.c>
    <FilesMatch "\.(json)$">
        Header set Access-Control-Allow-Origin "*"
        Header set Cache-Control "public, max-age=21600"
    </FilesMatch>
</IfModule>

# Protect the upload endpoint - only allow POST
<Files "upload_catalog.php">
    # Block GET requests to the upload script (prevent browser access)
    <If "%{REQUEST_METHOD} == 'GET'">
        Require all denied
    </If>
</Files>

# Block direct access to sensitive files
<FilesMatch "\.(py|sh|log)$">
    Require all denied
</FilesMatch>

# BEGIN cPanel-generated php ini directives, do not edit
# Manual editing of this file may result in unexpected behavior.
# To make changes to this file, use the cPanel MultiPHP INI Editor (Home >> Software >> MultiPHP INI Editor)
# For more information, read our documentation (https://go.cpanel.net/EA4ModifyINI)
<IfModule php8_module>
   php_flag display_errors Off
   php_value max_execution_time 300
   php_value max_input_time 60
   php_value max_input_vars 1000
   php_value memory_limit 512M
   php_value post_max_size 516M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php83"
   php_value upload_max_filesize 512M
   php_flag zlib.output_compression Off
</IfModule>
<IfModule lsapi_module>
   php_flag display_errors Off
   php_value max_execution_time 300
   php_value max_input_time 60
   php_value max_input_vars 1000
   php_value memory_limit 512M
   php_value post_max_size 516M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php83"
   php_value upload_max_filesize 512M
   php_flag zlib.output_compression Off
</IfModule>
# END cPanel-generated php ini directives, do not edit
